# ============================================================
# PeoplePulse — Environment Variables
# Copy to .env.local and fill in values
# ============================================================

# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/peoplepulse?schema=public"

# ─── Clerk Authentication ───────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

NEXT_PUBLIC_CLERK_SIGN_IN_URL="/login"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/signup"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# Comma-separated list of super admin emails
SUPER_ADMIN_EMAILS="admin@peoplepulse.co.bw"

# ─── Anthropic Claude (AI HR Assistant) ─────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Supabase Storage ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ─── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY="re_..."
NEXT_PUBLIC_EMAIL_FROM="PeoplePulse <noreply@peoplepulse.co.bw>"

# ─── SMS (Africa's Talking) ──────────────────────────────────
AFRICASTALKING_API_KEY="..."
AFRICASTALKING_USERNAME="sandbox"

# ─── Payments (DPO Pay — BWP) ────────────────────────────────
DPO_PAY_SERVICE_KEY="..."
DPO_PAY_ACCOUNT_ID="..."

# ─── Payments (Stripe — ZAR/USD expansion) ───────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# ─── App Config ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://peoplepulse.co.bw"
NEXT_PUBLIC_COMPANY_NAME="PeoplePulse"
NEXT_PUBLIC_COMPANY_TAGLINE="Smart HR. Botswana Built."